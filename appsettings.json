{
  "Bridge": {
    "Listen": "http://localhost:11434",
    "OllamaNative": "http://localhost:11436",
    "HealthCheckIntervalSeconds": 30,
    "StartupDelayMs": 500,
    "MaxBackendRestarts": 3,
    "LogRetentionDays": 7,
    "MetricsRetentionDays": 30
  },
  "Backends": {
    "llm-openvino": {
      "Id": "llm-openvino",
      "Executable": "C:\\Tools\\llama-openvino\\llama-server.exe",
      "Arguments": "-m {modelPath} --host 0.0.0.0 --port {port} -ngl 99",
      "Port": 8080,
      "WorkingDirectory": "C:\\Tools\\llama-openvino",
      "EnvironmentVariables": {
        "OPENVINO_DEVICE": "GPU",
        "SYCL_CACHE_PERSISTENT": "1"
      },
      "AutoStart": true,
      "HealthEndpoint": "/health",
      "AdapterType": "openai",
      "RuntimeVersion": "OpenVINO 2025.3"
    },
    "vision-openvino": {
      "Id": "vision-openvino",
      "Executable": "C:\\Tools\\llama-openvino\\llama-server.exe",
      "Arguments": "-m {modelPath} --mmproj {mmprojPath} --host 0.0.0.0 --port {port}",
      "Port": 8082,
      "WorkingDirectory": "C:\\Tools\\llama-openvino",
      "AutoStart": true,
      "HealthEndpoint": "/health",
      "AdapterType": "openai",
      "RuntimeVersion": "OpenVINO 2025.3"
    },
    "embed-openvino": {
      "Id": "embed-openvino",
      "Executable": "C:\\Tools\\llama-openvino\\llama-embed-server.exe",
      "Arguments": "-m {modelPath} --host 0.0.0.0 --port {port}",
      "Port": 8081,
      "WorkingDirectory": "C:\\Tools\\llama-openvino",
      "AutoStart": true,
      "HealthEndpoint": "/health",
      "AdapterType": "embed",
      "RuntimeVersion": "OpenVINO 2025.3"
    }
  },
  "Models": {
    "ov-llama3.1": {
      "BackendId": "llm-openvino",
      "ModelPath": "C:\\Models\\llama-3.1-8b-openvino.gguf",
      "ContextSize": 8192,
      "Device": "NPU",
      "FallbackDevice": "GPU"
    },
    "ov-mistral": {
      "BackendId": "llm-openvino",
      "ModelPath": "C:\\Models\\mistral-7b-openvino.gguf",
      "ContextSize": 32768,
      "Device": "GPU"
    },
    "ov-llava": {
      "BackendId": "vision-openvino",
      "ModelPath": "C:\\Models\\llava-1.6-mistral-7b.gguf",
      "MmprojPath": "C:\\Models\\mmproj-llava-f16.gguf",
      "Device": "GPU"
    },
    "ov-minicpm": {
      "BackendId": "vision-openvino",
      "ModelPath": "C:\\Models\\minicpm-v-2.6.gguf",
      "MmprojPath": "C:\\Models\\mmproj-minicpm-f16.gguf",
      "Device": "GPU"
    },
    "ov-embed": {
      "BackendId": "embed-openvino",
      "ModelPath": "C:\\Models\\bge-large-embed-v1.5-q8_0.gguf",
      "Device": "CPU"
    }
  }
}